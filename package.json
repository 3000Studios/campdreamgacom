{
  "name": "campdreamga-com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "build": "npm run generate:static && npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsup server/index.ts --format esm --target node20 --out-dir build/server --clean",
    "preview": "vite preview",
    "start": "node build/server/index.js",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "analyze": "cross-env ANALYZE=true vite build",
    "generate:static": "tsx scripts/generate-static.ts",
    "validate:pages-env": "tsx scripts/validate-pages-env.ts",
    "validate:env": "tsx scripts/validate-env.ts",
    "depcheck": "depcheck",
    "deps:check": "npx npm-check-updates",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,svg,toml,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.6.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "depcheck": "^1.4.7",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.0",
    "npm-check-updates": "^18.0.1",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "supertest": "^7.1.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.2",
    "vitest": "^3.1.4"
  }
}
